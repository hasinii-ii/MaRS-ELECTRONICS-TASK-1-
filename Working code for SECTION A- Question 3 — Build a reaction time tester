const int ledPin    = 13;
const int buttonPin = 2;  // INPUT_PULLUP

unsigned long ledOnTime  = 0;
bool waiting             = false;  // waiting for button press
bool ledIsOn             = false;

// Random delay before LED turns on: 2000–7000ms
unsigned long nextTrigger = 0;

void setup() {
  Serial.begin(9600);
  pinMode(ledPin,    OUTPUT);
  pinMode(buttonPin, INPUT_PULLUP);
  randomSeed(analogRead(A0));  // seed from floating pin
  nextTrigger = millis() + random(2000, 7000);
  Serial.println("Reaction Tester Ready! Wait for the LED...");
}

void loop() {
  unsigned long now = millis();

  // Turn LED on after random delay
  if (!ledIsOn && !waiting && now >= nextTrigger) {
    digitalWrite(ledPin, HIGH);
    ledOnTime = now;
    ledIsOn   = true;
    waiting   = true;
    Serial.println("LED ON! Press the button!");
  }

  // Detect button press (LOW because INPUT_PULLUP)
  if (waiting && digitalRead(buttonPin) == LOW) {
    unsigned long reactionTime = millis() - ledOnTime;
    digitalWrite(ledPin, LOW);
    ledIsOn = false;
    waiting = false;

    Serial.print("Reaction time: ");
    Serial.print(reactionTime);
    Serial.println(" ms");

    if      (reactionTime < 200) Serial.println("Lightning fast!");
    else if (reactionTime < 400) Serial.println("Great reflexes!");
    else if (reactionTime < 700) Serial.println("Average.");
    else                          Serial.println("Keep practicing!");

    Serial.println("---");
    delay(500); // debounce
    nextTrigger = millis() + random(2000, 7000);
    Serial.println("Get ready for the next round...");
  }
}
